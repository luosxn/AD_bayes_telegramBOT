# Telegram Bot Token (从 @BotFather 获取)
BOT_TOKEN=your_bot_token_here

# ============================================
# 数据库配置
# ============================================
# 支持 SQLite、PostgreSQL、MySQL
# 根据你的需求选择其中一种配置，注释掉其他配置

# --- SQLite (默认，适合单机部署) ---
DATABASE_URL=sqlite:///./data/spam_bot.db

# --- PostgreSQL (推荐用于生产环境) ---
# DATABASE_URL=postgresql://username:password@localhost:5432/spam_bot
# 示例: postgresql://bot_user:bot_pass@127.0.0.1:5432/spam_bot_db

# --- MySQL ---
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/spam_bot
# 示例: mysql+pymysql://bot_user:bot_pass@127.0.0.1:3306/spam_bot_db

# ============================================
# 机器人配置
# ============================================

# 垃圾消息判定阈值 (0-1之间，建议0.95)
# 值越高越严格，越低越宽松
SPAM_THRESHOLD=0.95

# 连续违规次数限制 (默认3次)
# 超过此次数将被自动封禁
MAX_VIOLATIONS=3

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
